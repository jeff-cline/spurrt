# Set in Vercel project settings (or .env.local for local dev).
# Never commit .env.local — see .gitignore.

# --- Phase 1 (waitlist) ---
# When unset, waitlist submissions are logged to the runtime console
# and the API still returns 200 — see lib/resend-client.ts.
RESEND_API_KEY=

# --- Phase 2+ (auth, God admin account) ---
# These are read by the seed script that creates the God admin user the
# first time the auth system runs in Phase 2. The seed script hashes the
# password (never stores plaintext) and then ignores GOD_ADMIN_PASSWORD
# on subsequent boots. Rotate the password from the admin panel after
# first login.
GOD_ADMIN_EMAIL=
GOD_ADMIN_PASSWORD=

# Phase 2: database (SQLite for local; swap to a Postgres URL for prod)
DATABASE_URL="file:./dev.db"

# Phase 2: Auth.js secret (run: openssl rand -base64 32)
AUTH_SECRET=
