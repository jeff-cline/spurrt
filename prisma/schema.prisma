generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  passwordHash  String?
  emailVerified DateTime?
  image         String?

  isGod         Boolean  @default(false)
  isAdmin       Boolean  @default(false)
  isTalent      Boolean  @default(false)
  isSupplier    Boolean  @default(false)
  isBenefactor  Boolean  @default(false)
  isContributor Boolean  @default(false)

  parentUserId  String?
  parent        User?    @relation("SubAccounts", fields: [parentUserId], references: [id])
  subAccounts   User[]   @relation("SubAccounts")

  permissions   Permission[]
  ledgerEntries LedgerEntry[]
  accounts      Account[]
  sessions      Session[]

  talentProfile         TalentProfile?
  opportunitiesPosted   Opportunity[] @relation("OpportunityPoster")
  opportunitiesAccepted Opportunity[] @relation("OpportunityAccepter")
  applications          OpportunityApplication[]

  listings              Listing[]              @relation("ListingSeller")
  purchases             Purchase[]             @relation("PurchaseBuyer")
  tradesSent            Trade[]                @relation("TradeFrom")
  tradesReceived        Trade[]                @relation("TradeTo")
  livesBalance          LivesBalance?
  livesExchangeRequests LivesExchangeRequest[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Permission {
  id      String  @id @default(cuid())
  userId  String
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  scope   String
  granted Boolean @default(true)
  @@unique([userId, scope])
}

// Auth.js v5 tables
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

// Spurrt double-entry ledger
model LedgerEntry {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  amount     Int
  direction  String
  category   String
  reference  String?
  notes      String?
  transferId String?
  createdAt  DateTime @default(now())
  @@index([userId])
  @@index([category])
  @@index([transferId])
}

// Single-row valuation
model Valuation {
  id           Int      @id @default(1)
  spurrtCents  Int      // value of 1 spurrt in USD cents (default 44400 = $444)
  poolCents    Int      // value of the profit pool in USD cents (default 1_000_000_000 = $10M)
  totalIssued  Int      @default(0)
  updatedById  String?
  updatedAt    DateTime @updatedAt
}

model TalentProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  headline      String
  bio           String?
  skills        String   // JSON-encoded list of strings
  jobsCompleted Int      @default(0)
  spurrtsEarned Int      @default(0)
  lastActiveAt  DateTime @default(now())
  visible       Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Opportunity {
  id          String   @id @default(cuid())
  posterId    String
  poster      User     @relation("OpportunityPoster", fields: [posterId], references: [id])
  title       String
  description String
  spurrts     Int      // total amount, sum of milestones if any (server enforces)
  category    String?
  status      String   @default("open") // open, accepted, in_progress, completed, cancelled
  accepterId  String?
  accepter    User?    @relation("OpportunityAccepter", fields: [accepterId], references: [id])
  acceptedAt  DateTime?
  completedAt DateTime?
  cancelledAt DateTime?
  milestones  Milestone[]
  applications OpportunityApplication[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([posterId])
  @@index([status])
}

model Milestone {
  id            String   @id @default(cuid())
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  description   String
  spurrts       Int
  released      Boolean  @default(false)
  releasedAt    DateTime?
  order         Int      @default(0)
}

model OpportunityApplication {
  id            String   @id @default(cuid())
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  applicantId   String
  applicant     User     @relation(fields: [applicantId], references: [id])
  message       String?
  status        String   @default("pending") // pending, accepted, declined
  createdAt     DateTime @default(now())
  @@unique([opportunityId, applicantId])
  @@index([applicantId])
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  emoji     String?
  gradient  String?
  order     Int       @default(0)
  active    Boolean   @default(true)
  listings  Listing[]
  createdAt DateTime  @default(now())
}

model Listing {
  id          String   @id @default(cuid())
  sellerId    String
  seller      User     @relation("ListingSeller", fields: [sellerId], references: [id])
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  title       String
  description String
  spurrtPrice Int
  imageUrl    String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  purchases   Purchase[]
  @@index([categoryId])
  @@index([sellerId])
}

model Purchase {
  id         String   @id @default(cuid())
  listingId  String
  listing    Listing  @relation(fields: [listingId], references: [id])
  buyerId    String
  buyer      User     @relation("PurchaseBuyer", fields: [buyerId], references: [id])
  amount     Int      // spurrts paid (gross)
  feeAmount  Int      // platform fee portion
  poolAmount Int      // routed to Spurrts to Success pool
  createdAt  DateTime @default(now())
  @@index([buyerId])
}

model Trade {
  id          String   @id @default(cuid())
  fromUserId  String
  fromUser    User     @relation("TradeFrom", fields: [fromUserId], references: [id])
  toUserId    String
  toUser      User     @relation("TradeTo", fields: [toUserId], references: [id])
  amount      Int
  note        String?
  status      String   @default("completed") // v1 always completed (no approval flow)
  createdAt   DateTime @default(now())
  @@index([fromUserId])
  @@index([toUserId])
}

model LivesBalance {
  userId    String   @id
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Int      @default(0)
  updatedAt DateTime @updatedAt
}

model LivesExchangeRequest {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  livesAmount Int
  cryptoAsset String   // "BTC" | "ETH" | etc — free text v1
  walletAddress String
  status    String   @default("pending") // pending, fulfilled, cancelled (manual god process v1)
  notes     String?
  createdAt DateTime @default(now())
  @@index([userId])
}

model SuccessPoolDistribution {
  id        String   @id @default(cuid())
  triggeredById String
  totalDistributed Int
  totalSpurrtsHeld Int  // basis for proportional split at trigger time
  recipientCount Int
  createdAt DateTime @default(now())
}
